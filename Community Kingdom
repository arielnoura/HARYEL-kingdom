        let filtered = [...npcs];
        const list = document.getElementById('npc-list');

        function render() {
            list.innerHTML = '';
            filtered.forEach(n => {
                list.innerHTML += `<div class="npc-card">
                    <h3 class="font-bold text-lg">${n.nome}</h3>
                    <p class="text-sm opacity-80">${n.razza} · ${n.classe || 'Nessuna classe'}</p>
                    <p class="mt-2 text-sm">${n.desc}</p>
                </div>`;
            });
        }

        document.getElementById('search-input').addEventListener('input', e => {
            const q = e.target.value.toLowerCase();
            filtered = npcs.filter(n => (n.nome+n.desc+n.razza+n.classe).toLowerCase().includes(q));
            render();
        });

        function sortData(type) {
            if(type === 'name-asc') filtered.sort((a,b) => a.nome.localeCompare(b.nome));
            if(type === 'name-desc') filtered.sort((a,b) => b.nome.localeCompare(a.nome));
            render();
        }

        function resetFilters() { filtered = [...npcs]; render(); }
        render();
